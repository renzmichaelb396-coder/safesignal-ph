{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.ts": {
      "includeFiles": "{node_modules/sql.js/dist/**,seed-data.json}"
    }
  },
  "rewrites": [
    { "source": "/api/events", "destination": "/api/events" },
    { "source": "/api/citizen/(.*)", "destination": "/api/index" },
    { "source": "/api/dispatch/(.*)", "destination": "/api/index" },
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
